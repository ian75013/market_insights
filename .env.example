# ── Application ────────────────────────────────────────────────
APP_ENV=dev
APP_NAME=Market Insights
DATABASE_URL=sqlite:///./market_insights.db

# ── LLM ────────────────────────────────────────────────────────
OPENAI_API_KEY=
LLM_BACKEND=fallback

# ── IBKR (Interactive Brokers) ─────────────────────────────────
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1

# ── Network & routing ─────────────────────────────────────────
# Set to true to enable real API calls to external providers
USE_NETWORK=false
# Provider for prices: sample | stooq | yahoo | alpha_vantage | coingecko | ibkr | auto
DEFAULT_PRICE_PROVIDER=sample

# ── Free API keys (all optional) ──────────────────────────────
# Alpha Vantage — https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=
# FRED — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# Financial Modeling Prep — https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=
# SEC EDGAR requires a User-Agent header (email for contact)
SEC_USER_AGENT=MarketInsights/1.0 contact@example.com

# ── Cache TTLs (seconds) ──────────────────────────────────────
CACHE_TTL_PRICES=900
CACHE_TTL_FUNDAMENTALS=3600
CACHE_TTL_MACRO=1800
CACHE_TTL_NEWS=600
