# ── Base de données PostgreSQL ─────────────────────────────────
POSTGRES_USER=market_insights
POSTGRES_PASSWORD=CHANGEZ_MOI_en_production
POSTGRES_DB=market_insights
# En local sans Docker, décommenter pour SQLite :
# DATABASE_URL=sqlite:///./market_insights.db

# ── Application ────────────────────────────────────────────────
APP_ENV=dev
APP_NAME=Market Insights

# ── Network ────────────────────────────────────────────────────
USE_NETWORK=false
DEFAULT_PRICE_PROVIDER=sample

# ── IBKR ───────────────────────────────────────────────────────
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1

# ── Data API keys ─────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=
FMP_API_KEY=
SEC_USER_AGENT=MarketInsights/1.0 contact@example.com

# ── LLM ────────────────────────────────────────────────────────
LLM_BACKEND=litellm
LLM_MODEL=local-private
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=800
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=sk-change-me-super-admin
LITELLM_SHARED_NETWORK=litellm-gateway-vps_llmnet
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
LMSTUDIO_BASE_URL=http://localhost:1234
LMSTUDIO_MODEL=default

# ── RAG ────────────────────────────────────────────────────────
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_USE_VECTORS=true
RAG_TOP_K=5
RAG_CHUNK_SIZE=400
RAG_CHUNK_OVERLAP=60

# ── Cache ──────────────────────────────────────────────────────
CACHE_TTL_PRICES=900
CACHE_TTL_FUNDAMENTALS=3600
CACHE_TTL_MACRO=1800
CACHE_TTL_NEWS=600

# ── Airflow (optionnel: docker-compose.airflow.yml) ───────────
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=CHANGE_ME_AIRFLOW_DB
AIRFLOW_DB_NAME=airflow
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME_AIRFLOW_ADMIN
AIRFLOW_ADMIN_EMAIL=admin@example.com

# Bind Airflow webserver. For VPN-only exposure, set this to VPN IP.
# Example: AIRFLOW_WEBSERVER_BIND=10.8.0.2
AIRFLOW_WEBSERVER_BIND=127.0.0.1
AIRFLOW_BASE_URL=http://localhost:8080
