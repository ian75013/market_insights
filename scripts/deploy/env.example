# Common deployment env examples
APP_NAME=market-insights
IMAGE_TAG=latest

# OVH target
SSH_USER=ubuntu
SSH_HOST=1.2.3.4
SSH_PORT=22
APP_DIR=/opt/market_insights
GIT_REPO=git@github.com:ian75013/market_insights.git
GIT_BRANCH=main
COMPOSE_FILE=docker-compose.ovh-apache.yml
APP_DOMAIN=market-insight.example.com

# Reserved targets (not wired yet)
AWS_REGION=eu-west-3
AWS_ACCOUNT_ID=123456789012

AZ_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZ_RESOURCE_GROUP=rg-market-insights
AZ_LOCATION=westeurope
AZ_ACR_NAME=marketinsightsacr
AZ_CONTAINERAPPS_ENV=market-insights-env

KUBE_CONTEXT=
K8S_API_IMAGE=registry.example.com/market-insights-api:latest
K8S_FRONTEND_IMAGE=registry.example.com/market-insights-frontend:latest
