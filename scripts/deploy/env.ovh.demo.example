# Example OVH env with demo placeholders
APP_NAME=market-insights
IMAGE_TAG=latest

SSH_USER=ubuntu
SSH_HOST=vps.example.com
SSH_PORT=22

GIT_REPO=git@github.com:ian75013/market_insights.git
GIT_BRANCH=main
APP_DIR=/opt/market_insights
COMPOSE_FILE=docker-compose.ovh-apache.yml
# Enable Airflow in prod by combining OVH stack + Airflow override
COMPOSE_FILES=docker-compose.ovh-apache.yml,docker-compose.airflow.yml

SYNC_LOCAL_OVERLAY=true
SYNC_DOTENV=true
ENABLE_APACHE_CONFIG=true
CERTBOT_AUTOCONFIG=true
CERTBOT_EMAIL=contact@doctumconsilium.com

APP_DOMAIN=market-insight.doctumconsilium.com
SSL_CERT=/etc/letsencrypt/live/market-insight.doctumconsilium.com/fullchain.pem
SSL_KEY=/etc/letsencrypt/live/market-insight.doctumconsilium.com/privkey.pem

AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=change-me-airflow-db
AIRFLOW_DB_NAME=airflow
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change-me-airflow-admin
AIRFLOW_ADMIN_EMAIL=admin@doctumconsilium.com
# Replace with your VPN interface IP to restrict UI access to VPN only
AIRFLOW_WEBSERVER_BIND=10.8.0.2

ASK_SUDO_PASSWORD=true
SUDO_PASSWORD=
