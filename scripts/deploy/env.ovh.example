# OVH deployment env for market_insights behind host Apache2
APP_NAME=market-insights
IMAGE_TAG=latest

# VPS access
SSH_USER=ubuntu
SSH_HOST=REPLACE_WITH_VPS_IP_OR_HOSTNAME
SSH_PORT=22

# Repository deployment source on VPS
GIT_REPO=REPLACE_WITH_GIT_REPO_URL
GIT_BRANCH=main
APP_DIR=/opt/market_insights
LOCAL_ENV_FILE=.env.ovh

# Docker compose file to run on VPS
COMPOSE_FILE=docker-compose.ovh-apache.yml
# Optional: use multiple compose files (comma-separated, no spaces)
# Production with Airflow enabled:
COMPOSE_FILES=docker-compose.ovh-apache.yml,docker-compose.airflow.yml

# Deployment behavior
SYNC_LOCAL_OVERLAY=true
SYNC_DOTENV=true
ENABLE_APACHE_CONFIG=true
CERTBOT_AUTOCONFIG=true
CERTBOT_EMAIL=contact@example.com

# Domain and TLS used by Apache2 host
APP_DOMAIN=market-insight.REPLACE_WITH_YOUR_DOMAIN
SSL_CERT=/etc/letsencrypt/live/market-insight.REPLACE_WITH_YOUR_DOMAIN/fullchain.pem
SSL_KEY=/etc/letsencrypt/live/market-insight.REPLACE_WITH_YOUR_DOMAIN/privkey.pem
API_BIND_PORT=18000
FRONTEND_BIND_PORT=18080

# Airflow (optional)
# This file is intended to be copied to .env.ovh and used both for deploy control
# and as the runtime env copied to the remote VPS.
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=CHANGE_ME_AIRFLOW_DB
AIRFLOW_DB_NAME=airflow
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME_AIRFLOW_ADMIN
AIRFLOW_ADMIN_EMAIL=admin@example.com

# VPN-first exposure: bind Airflow web UI to VPN IP only.
# Keep a dedicated host port distinct from market_screener Airflow (18088).
# Example OpenVPN subnet: 10.8.0.2
AIRFLOW_WEBSERVER_BIND=10.8.0.2
AIRFLOW_WEBSERVER_PORT=18089
AIRFLOW_BASE_URL=http://10.8.0.2:18089

# Security: prefer prompt mode
ASK_SUDO_PASSWORD=true
SUDO_PASSWORD=
